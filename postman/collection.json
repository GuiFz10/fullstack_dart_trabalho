{
  "info": {
    "name": "Biblioteca API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleção da API Biblioteca com duas entidades: autores e livros."
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Autores",
      "item": [
        {
          "name": "GET Listar autores",
          "request": {
            "method": "GET",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "description": "Lista todos os autores cadastrados.",
            "url": {"raw": "{{base_url}}/autores", "host": ["{{base_url}}"], "path": ["autores"]}
          }
        },
        {
          "name": "GET Buscar autor por ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "description": "Busca um autor específico pelo ID.",
            "url": {"raw": "{{base_url}}/autores/1", "host": ["{{base_url}}"], "path": ["autores", "1"]}
          }
        },
        {
          "name": "POST Criar autor",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "description": "Cria um novo autor.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Machado de Assis\",\n  \"nacionalidade\": \"Brasileiro\"\n}"
            },
            "url": {"raw": "{{base_url}}/autores", "host": ["{{base_url}}"], "path": ["autores"]}
          }
        },
        {
          "name": "PUT Atualizar autor",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "description": "Atualiza um autor existente pelo ID.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Machado de Assis\",\n  \"nacionalidade\": \"Brasil\"\n}"
            },
            "url": {"raw": "{{base_url}}/autores/1", "host": ["{{base_url}}"], "path": ["autores", "1"]}
          }
        },
        {
          "name": "DELETE Remover autor",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "description": "Remove um autor pelo ID.",
            "url": {"raw": "{{base_url}}/autores/1", "host": ["{{base_url}}"], "path": ["autores", "1"]}
          }
        }
      ]
    },
    {
      "name": "Livros",
      "item": [
        {
          "name": "GET Listar livros",
          "request": {
            "method": "GET",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "description": "Lista todos os livros cadastrados.",
            "url": {"raw": "{{base_url}}/livros", "host": ["{{base_url}}"], "path": ["livros"]}
          }
        },
        {
          "name": "GET Buscar livro por ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "description": "Busca um livro específico pelo ID.",
            "url": {"raw": "{{base_url}}/livros/1", "host": ["{{base_url}}"], "path": ["livros", "1"]}
          }
        },
        {
          "name": "GET Listar livros de um autor",
          "request": {
            "method": "GET",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "description": "Lista os livros relacionados a um autor.",
            "url": {"raw": "{{base_url}}/autores/1/livros", "host": ["{{base_url}}"], "path": ["autores", "1", "livros"]}
          }
        },
        {
          "name": "POST Criar livro",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "description": "Cria um novo livro informando o autorId.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Dom Casmurro\",\n  \"ano\": 1899,\n  \"autorId\": 1\n}"
            },
            "url": {"raw": "{{base_url}}/livros", "host": ["{{base_url}}"], "path": ["livros"]}
          }
        },
        {
          "name": "PUT Atualizar livro",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "description": "Atualiza um livro existente pelo ID.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Dom Casmurro - Edição Revisada\",\n  \"ano\": 1900,\n  \"autorId\": 1\n}"
            },
            "url": {"raw": "{{base_url}}/livros/1", "host": ["{{base_url}}"], "path": ["livros", "1"]}
          }
        },
        {
          "name": "DELETE Remover livro",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "description": "Remove um livro pelo ID.",
            "url": {"raw": "{{base_url}}/livros/1", "host": ["{{base_url}}"], "path": ["livros", "1"]}
          }
        }
      ]
    }
  ]
}
